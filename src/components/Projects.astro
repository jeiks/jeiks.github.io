---
import { projects } from "../data/projects";
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";
---

<section id="projects" class="py-36">

    <Container>

        <SectionTitle
            overline="Research Projects"
            title="Featured Research Projects"
            description="Selected projects in Artificial Intelligence, Deep Learning and Open Source research."
        />

        <div class="mt-16 grid gap-8 md:grid-cols-2">

            {
                projects.map((project) => (

                    <article
                        class="rounded-3xl border border-slate-200 bg-white p-8 transition duration-300 hover:-translate-y-1 hover:shadow-2xl">

                        <h3 class="text-2xl font-bold">
                            {project.title}
                        </h3>

                        <p class="mt-4 leading-relaxed text-slate-600">
                            {project.description}
                        </p>

                        <div class="mt-6 flex flex-wrap gap-2">

                            {
                                project.technologies.map((tech) => (

                                    <span
                                        class="rounded-full border border-slate-300 px-3 py-1 text-sm text-slate-600">

                                        {tech}

                                    </span>

                                ))
                            }

                        </div>

                        <div class="mt-8 flex items-center justify-between">

                            <span class="text-sm uppercase tracking-wider text-slate-500">
                                {project.category}
                            </span>

                            <span class="text-sm text-slate-500">
                                {project.year}
                            </span>

                        </div>

                        
                        <div class="mt-8 flex gap-6">

                            {
                                project.website && (
                                    <a
                                        href={project.website}
                                        target="_blank"
                                        class="font-medium text-blue-600 hover:underline">

                                        Website →

                                    </a>
                                )
                            }

                            {
                                project.github && (
                                    <a
                                        href={project.github}
                                        target="_blank"
                                        class="font-medium text-blue-600 hover:underline">

                                        GitHub →

                                    </a>
                                )
                            }

                        </div>
                        

                    </article>

                ))
            }

        </div>

    </Container>

</section>