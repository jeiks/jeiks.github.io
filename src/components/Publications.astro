---
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";
---

<section id="publications" class="py-36">

    <Container>

        <SectionTitle
            overline="Publications"
            title="Selected publications"
            description="Research contributions in Artificial Intelligence, Deep Learning, Computer Vision and Model Extraction."
        />

        <div class="mt-16 space-y-8">

            <article class="rounded-3xl border border-slate-200 bg-white p-8">

                <div class="flex items-start justify-between">

                    <div>

                        <p class="text-sm uppercase tracking-widest text-blue-600">
                            Pattern Recognition
                        </p>

                        <h3 class="mt-2 text-2xl font-semibold">
                            Copycat CNN: Are Random Non-Labeled Data Enough to Steal Knowledge from Black-box Models?
                        </h3>

                        <p class="mt-4 text-slate-600">
                            Extended journal version of the original Copycat CNN method, demonstrating that unlabeled natural images can successfully perform model extraction attacks.
                        </p>

                    </div>

                    <span class="text-slate-500">
                        2021
                    </span>

                </div>

                <div class="mt-6 flex gap-6">

                    <a
                        href="https://github.com/jeiks/Stealing_DL_Models"
                        target="_blank"
                        class="font-medium text-blue-600 hover:underline">

                        Project →

                    </a>

                    <a
                        href="https://arxiv.org/abs/1811.07118"
                        target="_blank"
                        class="font-medium text-blue-600 hover:underline">

                        arXiv →

                    </a>

                </div>

            </article>

            <article class="rounded-3xl border border-slate-200 bg-white p-8">

                <div class="flex items-start justify-between">

                    <div>

                        <p class="text-sm uppercase tracking-widest text-blue-600">
                            IJCNN
                        </p>

                        <h3 class="mt-2 text-2xl font-semibold">
                            Stealing Knowledge by Persuading Confession with Random Non-Labeled Data
                        </h3>

                        <p class="mt-4 text-slate-600">
                            Original proposal of the Copycat CNN method presented at the International Joint Conference on Neural Networks.
                        </p>

                    </div>

                    <span class="text-slate-500">
                        2018
                    </span>

                </div>

                <div class="mt-6 flex gap-6">

                    <a
                        href="https://github.com/jeiks/Stealing_DL_Models"
                        target="_blank"
                        class="font-medium text-blue-600 hover:underline">

                        Project →

                    </a>

                    <a
                        href="https://arxiv.org/abs/1811.07118"
                        target="_blank"
                        class="font-medium text-blue-600 hover:underline">

                        arXiv →

                    </a>

                </div>

            </article>

            <article class="rounded-3xl border border-slate-200 bg-white p-8">

                <div class="flex items-start justify-between">

                    <div>

                        <p class="text-sm uppercase tracking-widest text-blue-600">
                            Ph.D. Thesis
                        </p>

                        <h3 class="mt-2 text-2xl font-semibold">
                            Copycat CNN: Convolutional Neural Network Extraction Attack with Unlabeled Natural Images
                        </h3>

                        <p class="mt-4 text-slate-600">
                            Doctoral thesis describing the complete framework, datasets, experiments and software developed during the research.
                        </p>

                    </div>

                    <span class="text-slate-500">
                        2023
                    </span>

                </div>

                <div class="mt-6 flex gap-6">

                    <a
                        href="https://github.com/jeiks/Stealing_DL_Models"
                        target="_blank"
                        class="font-medium text-blue-600 hover:underline">

                        Website →

                    </a>

                    <a
                        href="https://github.com/jeiks/copycat_framework"
                        target="_blank"
                        class="font-medium text-blue-600 hover:underline">

                        GitHub →

                    </a>

                </div>

            </article>

        </div>

    </Container>

</section>